<!-- Scroll reveal -->
<script>
    (function() {
        const els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window)) {
            els.forEach(function(el) { el.classList.add('in'); });
            return;
        }
        const obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
                if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
            });
        }, { threshold: 0.12 });
        els.forEach(function(el) { obs.observe(el); });
    })();
</script>

<!-- Bento card mouse-glow effect -->
<script>
    (function() {
        document.querySelectorAll('.bcard').forEach(function(card) {
            card.addEventListener('mousemove', function(e) {
                const r = card.getBoundingClientRect();
                card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
                card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
            });
        });
    })();
</script>

<!-- ============================================================
     CAR-SEAT POV ROAD ANIMATION
     Renders a 2D perspective road seen from inside a car.
     The road fades into background content as user scrolls.
============================================================ -->
<script>
(function() {
    const canvas = document.getElementById('roadCanvas');
    const ctx = canvas.getContext('2d');

    let W, H, cx, hy, lastTime = 0, dashOffset = 0;

    // Resize handler
    function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
        cx = W / 2;
        hy = H * 0.42; // horizon y
    }
    resize();
    window.addEventListener('resize', resize);

    // Dashboard / car interior colours
    const DASH_H = H * 0.22;

    function drawFrame(ts) {
        const dt = ts - lastTime; lastTime = ts;

        // Scroll-based opacity: fade out road as user scrolls down
        const scrollFrac = Math.min(window.scrollY / (window.innerHeight * 0.8), 1);
        canvas.style.opacity = 1 - scrollFrac;

        ctx.clearRect(0, 0, W, H);

        // --- Sky gradient ---
        const sky = ctx.createLinearGradient(0, 0, 0, hy);
        sky.addColorStop(0, '#b0cce0');
        sky.addColorStop(0.5, '#d6e8f5');
        sky.addColorStop(1, '#e8d5b0');
        ctx.fillStyle = sky;
        ctx.fillRect(0, 0, W, hy);

        // --- Sun glow ---
        const sunX = W * 0.72, sunY = hy * 0.52;
        const sunGlow = ctx.createRadialGradient(sunX, sunY, 0, sunX, sunY, H * 0.28);
        sunGlow.addColorStop(0, 'rgba(255,220,100,0.55)');
        sunGlow.addColorStop(0.4, 'rgba(255,180,60,0.18)');
        sunGlow.addColorStop(1, 'rgba(255,150,50,0)');
        ctx.fillStyle = sunGlow;
        ctx.fillRect(0, 0, W, hy);

        // --- Road surface ---
        const roadLeft  = cx - W * 1.8;
        const roadRight = cx + W * 1.8;

        const road = ctx.createLinearGradient(0, hy, 0, H);
        road.addColorStop(0, '#6e6a64');
        road.addColorStop(0.4, '#5a5650');
        road.addColorStop(1, '#3e3b36');
        ctx.fillStyle = road;
        ctx.beginPath();
        ctx.moveTo(roadLeft, hy);
        ctx.lineTo(roadRight, hy);
        ctx.lineTo(W, H);
        ctx.lineTo(0, H);
        ctx.closePath();
        ctx.fill();

        // Road surface sheen
        const sheen = ctx.createLinearGradient(cx - 40, hy + 10, cx + 40, hy + 10);
        sheen.addColorStop(0, 'rgba(255,255,255,0)');
        sheen.addColorStop(0.5, 'rgba(255,255,255,0.04)');
        sheen.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = sheen;
        ctx.fillRect(0, hy, W, H - hy);

        // --- Lane markings ---
        dashOffset = (dashOffset + dt * 0.18) % 120;

        function vanish(t) {
            // t=0 at horizon, t=1 at bottom
            return {
                x: cx + (cx - cx) * (1 - t),
                y: hy + (H - hy) * t
            };
        }

        // Draw a single lane line via perspective projection
        function drawLaneLine(offsetFrac) {
            // offsetFrac: -0.5 to 0.5 (fraction of road width at bottom)
            const bottomX = cx + offsetFrac * W;
            const vpX = cx; // vanishing point x

            ctx.save();
            ctx.strokeStyle = 'rgba(255,255,240,0.82)';
            ctx.lineWidth = 3;
            ctx.setLineDash([60, 60]);

            // Animate dash offset via dashOffset
            ctx.lineDashOffset = -dashOffset;

            ctx.beginPath();
            ctx.moveTo(vpX, hy + 4);
            ctx.lineTo(bottomX, H + 40);
            ctx.stroke();
            ctx.restore();
        }

        // Centre line (solid white)
        ctx.save();
        ctx.strokeStyle = 'rgba(255,255,200,0.9)';
        ctx.lineWidth = 2;
        ctx.setLineDash([]);
        ctx.beginPath();
        ctx.moveTo(cx, hy + 2);
        ctx.lineTo(cx, H + 10);
        ctx.stroke();
        ctx.restore();

        // Dashed lane lines
        drawLaneLine(-0.22);
        drawLaneLine( 0.22);
        drawLaneLine(-0.48);
        drawLaneLine( 0.48);

        // Shoulder lines (solid)
        function shoulder(offsetFrac) {
            ctx.save();
            ctx.strokeStyle = 'rgba(255,255,255,0.4)';
            ctx.lineWidth = 2;
            ctx.setLineDash([]);
            ctx.beginPath();
            ctx.moveTo(cx, hy + 2);
            ctx.lineTo(cx + offsetFrac * W, H + 10);
            ctx.stroke();
            ctx.restore();
        }
        shoulder(-0.72);
        shoulder( 0.72);

        // Roadside (grass/kerb)
        const grassL = ctx.createLinearGradient(0, hy, 0, H);
        grassL.addColorStop(0, '#8da86e');
        grassL.addColorStop(1, '#5a7a3a');
        ctx.fillStyle = grassL;
        // left grass
        ctx.beginPath();
        ctx.moveTo(cx - W * 0.72, H);
        ctx.lineTo(cx, hy + 2);
        ctx.lineTo(0, hy);
        ctx.lineTo(0, H);
        ctx.closePath();
        ctx.fill();
        // right grass
        ctx.beginPath();
        ctx.moveTo(cx + W * 0.72, H);
        ctx.lineTo(cx, hy + 2);
        ctx.lineTo(W, hy);
        ctx.lineTo(W, H);
        ctx.closePath();
        ctx.fill();

        // --- Dashboard (car interior) ---
        const dashY = H - DASH_H * 1.1;
        const dash = ctx.createLinearGradient(0, dashY, 0, H);
        dash.addColorStop(0, '#1a1510');
        dash.addColorStop(0.5, '#120e0b');
        dash.addColorStop(1, '#0a0806');
        ctx.fillStyle = dash;
        ctx.beginPath();
        // Dashboard shape - wider curve at bottom, narrows at top
        ctx.moveTo(0, H);
        ctx.lineTo(W, H);
        ctx.lineTo(W, dashY + DASH_H * 0.2);
        ctx.quadraticCurveTo(W * 0.75, dashY - DASH_H * 0.05, W * 0.5, dashY - DASH_H * 0.15);
        ctx.quadraticCurveTo(W * 0.25, dashY - DASH_H * 0.05, 0, dashY + DASH_H * 0.2);
        ctx.closePath();
        ctx.fill();

        // Dashboard surface sheen
        const dSheen = ctx.createLinearGradient(0, dashY, 0, dashY + 30);
        dSheen.addColorStop(0, 'rgba(255,255,255,0.06)');
        dSheen.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = dSheen;
        ctx.beginPath();
        ctx.moveTo(0, H);
        ctx.lineTo(W, H);
        ctx.lineTo(W, dashY + DASH_H * 0.2);
        ctx.quadraticCurveTo(W * 0.75, dashY - DASH_H * 0.05, W * 0.5, dashY - DASH_H * 0.15);
        ctx.quadraticCurveTo(W * 0.25, dashY - DASH_H * 0.05, 0, dashY + DASH_H * 0.2);
        ctx.closePath();
        ctx.fill();

        // Steering wheel
        const swCX = cx, swCY = H - DASH_H * 0.38;
        const swR  = Math.min(W, H) * 0.095;

        ctx.save();
        ctx.strokeStyle = '#2a2218';
        ctx.lineWidth = swR * 0.22;
        ctx.beginPath();
        ctx.arc(swCX, swCY, swR, 0, Math.PI * 2);
        ctx.stroke();

        // Hub
        ctx.fillStyle = '#3a2f22';
        ctx.beginPath();
        ctx.arc(swCX, swCY, swR * 0.26, 0, Math.PI * 2);
        ctx.fill();

        // Spokes
        ctx.strokeStyle = '#2a2218';
        ctx.lineWidth = swR * 0.14;
        [0, Math.PI * 0.67, Math.PI * 1.33].forEach(function(angle) {
            ctx.beginPath();
            ctx.moveTo(swCX + Math.cos(angle) * swR * 0.26, swCY + Math.sin(angle) * swR * 0.26);
            ctx.lineTo(swCX + Math.cos(angle) * swR * 0.9,  swCY + Math.sin(angle) * swR * 0.9);
            ctx.stroke();
        });

        // Wheel rim highlight
        ctx.strokeStyle = 'rgba(255,255,255,0.07)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(swCX - swR*0.15, swCY - swR*0.25, swR * 0.95, Math.PI * 1.1, Math.PI * 1.7);
        ctx.stroke();
        ctx.restore();

        // Instrument cluster glow
        const clustGlow = ctx.createRadialGradient(cx, swCY - swR * 1.3, 0, cx, swCY - swR * 1.3, swR * 1.8);
        clustGlow.addColorStop(0, 'rgba(29,179,168,0.12)');
        clustGlow.addColorStop(1, 'rgba(29,179,168,0)');
        ctx.fillStyle = clustGlow;
        ctx.fillRect(cx - swR*2, dashY, swR*4, DASH_H);

        // A-pillars (window frame lines)
        ctx.save();
        ctx.strokeStyle = '#1a1510';
        ctx.lineWidth = W * 0.025;
        // Left pillar
        ctx.beginPath();
        ctx.moveTo(0, hy - H * 0.05);
        ctx.lineTo(W * 0.18, dashY + DASH_H * 0.22);
        ctx.stroke();
        // Right pillar
        ctx.beginPath();
        ctx.moveTo(W, hy - H * 0.05);
        ctx.lineTo(W * 0.82, dashY + DASH_H * 0.22);
        ctx.stroke();
        ctx.restore();

        // Rear-view mirror
        const mirW = W * 0.11, mirH = H * 0.04;
        const mirX = cx - mirW / 2, mirY = H * 0.04;
        ctx.fillStyle = '#1a1510';
        ctx.beginPath();
        ctx.roundRect(mirX, mirY, mirW, mirH, 4);
        ctx.fill();
        // Mirror reflection (slight blue tint)
        ctx.fillStyle = 'rgba(180,210,230,0.15)';
        ctx.beginPath();
        ctx.roundRect(mirX + 2, mirY + 2, mirW - 4, mirH - 4, 3);
        ctx.fill();

        requestAnimationFrame(drawFrame);
    }

    requestAnimationFrame(drawFrame);
})();
</script>

