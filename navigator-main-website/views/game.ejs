<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Road Safety Game | Navigator +</title>
    <%- include('partials/styles.ejs') %>
    <style>
        body { padding-top: 86px; }
        .game-card { border: 1px solid var(--line); border-radius: var(--radius-panel); box-shadow: 0 4px 20px rgba(15,42,30,0.07); background: var(--card); }
    </style>
</head>
<body>
    <%- include('partials/navbar.ejs', { page: 'game' }) %>

    <div class="page-hero text-center">
        <div class="container">
            <h1 class="display-6">Play & Learn Road Safety</h1>
            <p class="mx-auto">Test your road safety knowledge and sharpen your instincts with our interactive game.</p>
        </div>
    </div>

    <div class="container my-4">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="game-card p-4 text-center" id="readable-content">
                    <h3>🎮 Play the Road Safety Game</h3>
                    <p class="text-muted">Head over to our interactive game to practise spotting hazards, making safe choices, and reacting like a pro on the road.</p>
                    <!-- TODO: replace with the real game URL -->
                    <a href="https://example.com/road-safety-game" target="_blank" rel="noopener" class="btn btn-brand px-5 mt-2">Play the Game</a>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>
</body>
</html>
