<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | Navigator+</title>
    <meta name="description" content="Get in touch with the Navigator+ team. Report a road safety concern, send feedback, or reach out for help.">
    <%- include('partials/styles.ejs') %>
    <style>
        body { padding-top: 86px; }

        /* ---- Contact Cards ---- */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.4fr;
            gap: 24px;
            margin-bottom: 48px;
        }
        @media (max-width: 768px) {
            .contact-grid { grid-template-columns: 1fr; }
        }

        .contact-info-stack {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .info-card {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: var(--radius-panel);
            padding: 24px;
            box-shadow: 0 4px 24px rgba(15,42,30,0.07);
            transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease;
            position: relative;
            overflow: hidden;
        }
        .info-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
        }
        .info-card:nth-child(1)::before { background: linear-gradient(90deg, var(--brand-teal), var(--brand-teal-deep)); }
        .info-card:nth-child(2)::before { background: linear-gradient(90deg, var(--brand-amber), var(--brand-yellow-dark)); }
        .info-card:nth-child(3)::before { background: linear-gradient(90deg, var(--brand-red), var(--brand-red-dark)); }
        .info-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px -15px rgba(15,42,30,0.18);
        }
        .info-card-head {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }
        .info-card-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }
        .info-card:nth-child(1) .info-card-icon { background: rgba(29,179,168,0.12); }
        .info-card:nth-child(2) .info-card-icon { background: rgba(217,154,43,0.12); }
        .info-card:nth-child(3) .info-card-icon { background: rgba(201,24,74,0.12); }
        .info-card h5 {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1rem;
            margin: 0;
        }
        .info-card p {
            font-size: 14px;
            color: var(--ink-muted);
            margin: 0;
            line-height: 1.7;
        }
        .info-card a {
            color: var(--brand-teal);
            text-decoration: none;
            font-weight: 600;
        }
        .info-card a:hover {
            color: var(--brand-teal-deep);
            text-decoration: underline;
        }

        /* ---- Form Card ---- */
        .form-card {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: var(--radius-panel);
            padding: 36px;
            box-shadow: 0 4px 24px rgba(15,42,30,0.07);
        }
        .form-card h3 {
            font-family: var(--font-display);
            font-size: 1.4rem;
            margin-bottom: 6px;
        }
        .form-card .form-subtitle {
            font-size: 14px;
            color: var(--ink-muted);
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 13px;
            color: var(--ink);
            margin-bottom: 6px;
            letter-spacing: 0.3px;
        }
        .form-input {
            width: 100%;
            border: 1.5px solid var(--line);
            border-radius: 14px;
            padding: 12px 16px;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--ink);
            background: var(--paper);
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
            outline: none;
        }
        .form-input:focus {
            border-color: var(--brand-teal);
            box-shadow: 0 0 0 3px rgba(29,179,168,0.14);
        }
        textarea.form-input {
            resize: vertical;
            min-height: 120px;
        }
        .form-select {
            width: 100%;
            border: 1.5px solid var(--line);
            border-radius: 14px;
            padding: 12px 16px;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--ink);
            background: var(--paper);
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
            outline: none;
            cursor: pointer;
            -webkit-appearance: none;
        }
        .form-select:focus {
            border-color: var(--brand-teal);
            box-shadow: 0 0 0 3px rgba(29,179,168,0.14);
        }

        /* ---- Success message ---- */
        .form-success {
            display: none;
            text-align: center;
            padding: 40px 20px;
        }
        .form-success .success-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
        .form-success h4 {
            font-family: var(--font-display);
            color: var(--brand-teal-deep);
            margin-bottom: 8px;
        }
        .form-success p {
            font-size: 14px;
            color: var(--ink-muted);
        }

        /* ---- FAQ ---- */
        .faq-section {
            margin-bottom: 48px;
        }
        .faq-section h3 {
            font-family: var(--font-display);
            font-size: 1.4rem;
            margin-bottom: 20px;
            text-align: center;
        }
        .faq-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 16px;
        }
        .faq-item {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 22px;
            box-shadow: 0 2px 12px rgba(15,42,30,0.05);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .faq-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px -12px rgba(15,42,30,0.15);
        }
        .faq-item h6 {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 0.92rem;
            margin-bottom: 8px;
            color: var(--ink);
        }
        .faq-item p {
            font-size: 13.5px;
            color: var(--ink-muted);
            margin: 0;
            line-height: 1.6;
        }

        /* ---- Emergency Banner ---- */
        .emergency-banner {
            background: linear-gradient(135deg, rgba(201,24,74,0.08) 0%, rgba(201,24,74,0.04) 100%);
            border: 1px solid rgba(201,24,74,0.18);
            border-radius: var(--radius-panel);
            padding: 28px 32px;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 48px;
        }
        .emergency-banner .em-icon {
            font-size: 36px;
            flex-shrink: 0;
        }
        .emergency-banner h5 {
            font-family: var(--font-display);
            font-weight: 700;
            margin-bottom: 4px;
            color: var(--brand-red-dark);
        }
        .emergency-banner p {
            font-size: 14px;
            color: var(--ink-muted);
            margin: 0;
        }
        .emergency-banner a {
            color: var(--brand-red);
            font-weight: 600;
        }
        @media (max-width: 576px) {
            .emergency-banner { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar.ejs', { page: 'contact' }) %>

    <div class="page-hero text-center">
        <div class="container">
            <h1 class="display-6">We're Here to Help</h1>
            <p class="mx-auto">Questions, feedback, or a road safety concern to report? Reach out and we'll get back to you.</p>
        </div>
    </div>

    <div class="container">

        <!-- Emergency Banner -->
        <div class="emergency-banner">
            <span class="em-icon">🚨</span>
            <div>
                <h5>In an Emergency?</h5>
                <p>Don't wait — call <strong>999</strong> (Police) or <strong>995</strong> (Ambulance/Fire) immediately. For more numbers, visit our <a href="/hotlines">Emergency Hotlines page</a>.</p>
            </div>
        </div>

        <!-- Contact Grid -->
        <div class="contact-grid" id="readable-content">

            <!-- Left: Info Cards -->
            <div class="contact-info-stack">
                <div class="info-card">
                    <div class="info-card-head">
                        <div class="info-card-icon">📧</div>
                        <h5>Email Us</h5>
                    </div>
                    <p>
                        General enquiries: <a href="mailto:hello@navigatorplus.sg">hello@navigatorplus.sg</a><br>
                        Report a concern: <a href="mailto:report@navigatorplus.sg">report@navigatorplus.sg</a>
                    </p>
                </div>

                <div class="info-card">
                    <div class="info-card-head">
                        <div class="info-card-icon">🕘</div>
                        <h5>Working Hours</h5>
                    </div>
                    <p>
                        Monday – Friday: 9:00 AM – 6:00 PM<br>
                        Saturday: 9:00 AM – 1:00 PM<br>
                        Sunday & Public Holidays: Closed
                    </p>
                </div>

                <div class="info-card">
                    <div class="info-card-head">
                        <div class="info-card-icon">⏱️</div>
                        <h5>Response Time</h5>
                    </div>
                    <p>
                        We aim to respond to all messages within <strong>24 hours</strong>. For urgent matters, please email us directly or use our hotlines.
                    </p>
                </div>
            </div>

            <!-- Right: Contact Form -->
            <div class="form-card">
                <h3>✉️ Send Us a Message</h3>
                <p class="form-subtitle">Fill out the form below and we'll get back to you shortly.</p>

                <form id="contactForm" onsubmit="submitContactForm(event)">
                    <div class="form-group">
                        <label for="contactName">Your Name</label>
                        <input type="text" class="form-input" id="contactName" name="name" placeholder="Enter your name" required>
                    </div>

                    <div class="form-group">
                        <label for="contactEmail">Email Address</label>
                        <input type="email" class="form-input" id="contactEmail" name="email" placeholder="you@example.com" required>
                    </div>

                    <div class="form-group">
                        <label for="contactTopic">Topic</label>
                        <select class="form-select" id="contactTopic" name="topic" required>
                            <option value="" disabled selected>Select a topic</option>
                            <option value="general">General Enquiry</option>
                            <option value="feedback">Feedback / Suggestion</option>
                            <option value="report">Report a Road Safety Concern</option>
                            <option value="bug">Report a Bug</option>
                            <option value="partnership">Partnership / Collaboration</option>
                            <option value="other">Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="contactMessage">Your Message</label>
                        <textarea class="form-input" id="contactMessage" name="message" placeholder="Tell us what's on your mind…" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-brand px-5 w-100" id="submitBtn">
                        Send Message
                    </button>
                </form>

                <div class="form-success" id="formSuccess">
                    <div class="success-icon">✅</div>
                    <h4>Message Sent!</h4>
                    <p>Thank you for reaching out. We'll get back to you within 24 hours.</p>
                    <button class="btn btn-brand-teal px-4 mt-3" onclick="resetForm()">Send Another Message</button>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="faq-section">
            <h3>❓ Frequently Asked Questions</h3>
            <div class="faq-grid">
                <div class="faq-item">
                    <h6>How do I report a road safety issue?</h6>
                    <p>Use the form above and select "Report a Road Safety Concern", or email us at report@navigatorplus.sg with details and location.</p>
                </div>
                <div class="faq-item">
                    <h6>Is Navigator+ free to use?</h6>
                    <p>Yes! Navigator+ is completely free. Our mission is to make Singapore's roads safer for everyone, especially youth.</p>
                </div>
                <div class="faq-item">
                    <h6>Can I volunteer or collaborate?</h6>
                    <p>We'd love that! Select "Partnership / Collaboration" in the contact form or email us directly. All help is welcome.</p>
                </div>
                <div class="faq-item">
                    <h6>How accurate is the AI assistant?</h6>
                    <p>Our Navigator+ AI is trained on Singapore road safety data. For critical emergencies, always contact the relevant authorities directly.</p>
                </div>
                <div class="faq-item">
                    <h6>Can I use Navigator+ content for school projects?</h6>
                    <p>Absolutely! Feel free to reference our content for educational purposes. We'd appreciate a credit back to navigatorplus.sg.</p>
                </div>
                <div class="faq-item">
                    <h6>I found a bug. How do I report it?</h6>
                    <p>Select "Report a Bug" in the topic dropdown and describe what happened. Screenshots or screen recordings help us fix it faster!</p>
                </div>
            </div>
        </div>

    </div>

    <%- include('partials/footer.ejs') %>

    <script>
        function submitContactForm(e) {
            e.preventDefault();
            const form = document.getElementById('contactForm');
            const success = document.getElementById('formSuccess');
            const btn = document.getElementById('submitBtn');

            btn.textContent = 'Sending...';
            btn.disabled = true;

            // Simulate sending (replace with real endpoint if available)
            setTimeout(() => {
                form.style.display = 'none';
                document.querySelector('.form-subtitle').style.display = 'none';
                document.querySelector('.form-card h3').style.display = 'none';
                success.style.display = 'block';
            }, 800);
        }

        function resetForm() {
            const form = document.getElementById('contactForm');
            const success = document.getElementById('formSuccess');
            const btn = document.getElementById('submitBtn');

            form.reset();
            form.style.display = 'block';
            document.querySelector('.form-subtitle').style.display = 'block';
            document.querySelector('.form-card h3').style.display = 'block';
            success.style.display = 'none';
            btn.textContent = 'Send Message';
            btn.disabled = false;
        }
    </script>
</body>
</html>
