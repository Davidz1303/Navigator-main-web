<!-- Floating chatbot button -->
<button id="openChatButton" class="chat-float" aria-label="Open Navigator AI chat">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
</button>

<!-- Chatbot popup -->
<div id="chatPopup" class="chat-popup">
    <div class="chat-header">
        <div class="chat-header-info">
            <div class="chat-avatar">AI</div>
            <div>
                <h3>Navigator AI</h3>
                <p>Road Safety Assistant</p>
            </div>
        </div>
        <button id="closeChatButton" class="close-chat" aria-label="Close chat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>

    <div id="chatMessages" class="chat-messages">
        <div class="message bot-message">
            Hello! Ask me anything about road safety, pedestrians, cycling, PMDs, safe driving or road accidents.
        </div>
    </div>

    <form id="chatForm" class="chat-input-area">
        <input
            type="text"
            id="userInput"
            placeholder="Ask a road-safety question..."
            autocomplete="off"
            required
        >
        <button type="submit" id="sendButton">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
        </button>
    </form>
</div>

<style>
    .chat-float {
        position: fixed;
        right: 28px;
        bottom: 28px;
        width: 60px;
        height: 60px;
        border: none;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brand-teal), var(--brand-red));
        color: white;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 10px 30px -8px rgba(29,179,168,0.5);
        z-index: 999;
        transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .chat-float svg { width: 26px; height: 26px; }
    .chat-float:hover {
        transform: scale(1.1) translateY(-2px);
        box-shadow: 0 18px 40px -8px rgba(201,24,74,0.5);
    }

    .chat-popup {
        position: fixed;
        right: 28px;
        bottom: 106px;
        width: 370px;
        height: 520px;
        background: var(--card);
        border-radius: 24px;
        box-shadow: 0 24px 70px -20px rgba(15, 42, 30, 0.35);
        border: 1px solid var(--line);
        overflow: hidden;
        display: none;
        flex-direction: column;
        z-index: 1000;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }
    .chat-popup.open { display: flex; }

    .chat-header {
        background: var(--ink);
        color: white;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }
    .chat-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 100% 0%, rgba(29,179,168,0.2) 0%, transparent 55%);
        pointer-events: none;
    }
    .chat-header-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .chat-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brand-teal), var(--brand-red));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 12px;
        color: white;
        flex-shrink: 0;
    }
    .chat-header h3 {
        margin: 0;
        font-family: var(--font-display);
        font-size: 16px;
        color: white;
        font-weight: 700;
    }
    .chat-header p {
        margin: 2px 0 0;
        font-size: 11.5px;
        color: rgba(216,237,233,0.7);
    }

    .close-chat {
        border: none;
        background: rgba(255,255,255,0.1);
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
        z-index: 1;
    }
    .close-chat svg { width: 16px; height: 16px; }
    .close-chat:hover { background: rgba(255,255,255,0.2); }

    .chat-messages {
        flex: 1;
        padding: 18px;
        overflow-y: auto;
        background: var(--paper);
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .message {
        max-width: 80%;
        padding: 11px 14px;
        border-radius: 18px;
        line-height: 1.45;
        font-size: 14px;
        white-space: pre-wrap;
    }
    .bot-message {
        background: var(--card);
        color: var(--ink);
        margin-right: auto;
        border: 1px solid var(--line);
        border-bottom-left-radius: 6px;
        box-shadow: 0 2px 8px rgba(15,42,30,0.06);
    }
    .user-message {
        background: linear-gradient(135deg, var(--brand-teal), var(--brand-teal-deep));
        color: white;
        margin-left: auto;
        border-bottom-right-radius: 6px;
    }

    .chat-input-area {
        display: flex;
        padding: 14px;
        border-top: 1px solid var(--line);
        background: var(--card);
        gap: 10px;
    }
    #userInput {
        flex: 1;
        padding: 10px 14px;
        border: 1.5px solid var(--line);
        border-radius: 999px;
        outline: none;
        font-family: var(--font-body);
        font-size: 14px;
        background: var(--paper);
        color: var(--ink);
        transition: border-color 0.2s ease;
    }
    #userInput:focus { border-color: var(--brand-teal); }
    #userInput::placeholder { color: var(--ink-muted); opacity: 0.7; }

    #sendButton {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brand-teal), var(--brand-red));
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 6px 16px -6px rgba(29,179,168,0.4);
    }
    #sendButton:hover { transform: scale(1.08); box-shadow: 0 10px 22px -6px rgba(29,179,168,0.55); }
    #sendButton:disabled { background: #ccc; cursor: not-allowed; transform: none; box-shadow: none; }

    @media screen and (max-width: 500px) {
        .chat-popup {
            right: 10px;
            bottom: 98px;
            width: calc(100% - 20px);
            height: 72vh;
        }
        .chat-float { right: 16px; bottom: 16px; }
    }
</style>

<script>
    (function () {
        const openChatButton = document.getElementById('openChatButton');
        const closeChatButton = document.getElementById('closeChatButton');
        const chatPopup = document.getElementById('chatPopup');
        const chatForm = document.getElementById('chatForm');
        const userInput = document.getElementById('userInput');
        const chatMessages = document.getElementById('chatMessages');
        const sendButton = document.getElementById('sendButton');

        openChatButton.addEventListener('click', function () {
            chatPopup.classList.add('open');
            openChatButton.style.display = 'none';
            userInput.focus();
        });

        closeChatButton.addEventListener('click', function () {
            chatPopup.classList.remove('open');
            openChatButton.style.display = 'flex';
        });

        function addMessage(text, messageType) {
            const message = document.createElement('div');
            message.classList.add('message', messageType);
            message.textContent = text;
            chatMessages.appendChild(message);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            return message;
        }

        chatForm.addEventListener('submit', async function (event) {
            event.preventDefault();
            const message = userInput.value.trim();
            if (message === '') return;

            addMessage(message, 'user-message');
            userInput.value = '';
            sendButton.disabled = true;

            const loadingMessage = addMessage('Navigator AI is thinking...', 'bot-message');

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ message: message })
                });
                const data = await response.json();
                loadingMessage.textContent = data.reply || 'Sorry, I could not answer that question.';
            } catch (error) {
                loadingMessage.textContent = 'Sorry, I could not connect to Navigator AI.';
            }

            sendButton.disabled = false;
            userInput.focus();
        });
    })();
</script>
