<!-- Read Aloud (Text-to-Speech) controls -->
<div class="d-flex justify-content-center gap-2 flex-wrap mb-4">
    <button class="btn btn-brand-outline" id="rewindBtn" style="color: var(--brand-red); border-color: var(--brand-red);" onclick="rewindReading()" disabled>⏪ Rewind</button>
    <button class="btn btn-brand-outline" id="playPauseBtn" style="color: var(--brand-red); border-color: var(--brand-red);" onclick="togglePlayPause()">🎙️ Read Aloud</button>
</div>

<script>
    // Reads the element with id="readable-content" on the page (falls back to
    // the whole body if a page hasn't marked a specific readable section).

    let fullText = '';       // the complete text being read
    let spokenChars = 0;     // how many characters of fullText we've already gotten through
    let currentUtterance = null;

    const REWIND_CHARS = 60; // roughly one sentence worth of rewind

    function getReadableText() {
        const target = document.getElementById('readable-content') || document.body;
        const rawText = target.textContent || target.innerText || '';
        return rawText.replace(/\s+/g, ' ').trim();
    }

    function setButtonStates({ rewind, playPauseLabel }) {
        document.getElementById('rewindBtn').disabled = !rewind;
        document.getElementById('playPauseBtn').innerHTML = playPauseLabel;
    }

    function speakFrom(startIndex) {
        const textToSpeak = fullText.substring(startIndex);
        if (!textToSpeak) return;

        speechSynthesis.cancel();

        const utterance = new SpeechSynthesisUtterance(textToSpeak);
        utterance.rate = 0.9;
        currentUtterance = utterance;

        // Track position within this utterance so rewind can find where we are
        utterance.onboundary = function(event) {
            if (event.name === 'word' || event.charIndex !== undefined) {
                spokenChars = startIndex + event.charIndex;
            }
        };

        utterance.onend = function() {
            if (currentUtterance === utterance) {
                spokenChars = fullText.length;
                setButtonStates({ rewind: false, playPauseLabel: '🎙️ Read Aloud' });
                currentUtterance = null;
                fullText = '';
            }
        };

        speechSynthesis.speak(utterance);
        setButtonStates({ rewind: true, playPauseLabel: '🎙️ Pause' });
    }

    function togglePlayPause() {
        // Nothing has been read yet, or previous reading finished — start fresh
        if (!speechSynthesis.speaking && !speechSynthesis.paused) {
            fullText = getReadableText();
            spokenChars = 0;
            speakFrom(0);
            return;
        }

        // Currently speaking — treat this as "pause" (also doubles as stop-and-park)
        if (speechSynthesis.speaking && !speechSynthesis.paused) {
            speechSynthesis.pause();
            setButtonStates({ rewind: true, playPauseLabel: '🎙️ Continue' });
            return;
        }

        // Currently paused — resume it
        if (speechSynthesis.paused) {
            speechSynthesis.resume();
            setButtonStates({ rewind: true, playPauseLabel: '🎙️ Pause' });
        }
    }

    function rewindReading() {
        if (!fullText) return;

        const wasPaused = speechSynthesis.paused;
        const newStart = Math.max(0, spokenChars - REWIND_CHARS);
        spokenChars = newStart;
        speakFrom(newStart);

        if (wasPaused) {
            speechSynthesis.pause();
            setButtonStates({ rewind: true, playPauseLabel: '🎙️ Continue' });
        }
    }

    // Stop any speech if the visitor navigates away from the page
    window.addEventListener('beforeunload', function() {
        speechSynthesis.cancel();
    });
</script>
